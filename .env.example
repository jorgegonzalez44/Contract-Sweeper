# Copy this file to .env and fill in your real key.
# .env is gitignored — it will never be committed.
# Get a free SAM.gov API key at https://sam.gov/data-services
SAM_API_KEY=paste_your_key_here

# HigherGov API key (optional) — used by run_all.py to auto-fetch HigherGov exports
HIGHERGOV_API_KEY=paste_your_highergov_key_here

# Codecov token (optional; required if repository is private and you want CI uploads)
# CODECOV_TOKEN=paste_your_codecov_token_here
